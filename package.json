{
  "name": "repobeacon",
  "version": "0.1.0",
  "description": "Terminal-first repo radar for local git state, fixture-backed GitHub health, and static dashboards.",
  "type": "module",
  "bin": {
    "repobeacon": "dist/cli.js"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE",
    "SECURITY.md",
    "CHANGELOG.md",
    "CONTRIBUTING.md",
    "CODE_OF_CONDUCT.md",
    "docs",
    "fixtures"
  ],
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "rm -rf dist && tsc -p tsconfig.build.json",
    "check": "tsc --noEmit -p tsconfig.json",
    "test": "tsx --test tests/*.test.ts",
    "smoke": "tsx scripts/smoke.ts",
    "package:smoke": "npm run build && test -f dist/cli.js && node scripts/verify-pack.mjs",
    "release:check": "npm run check && npm test && npm run build && npm run smoke && npm run package:smoke",
    "release:readiness": "node scripts/validate-release-readiness.mjs"
  },
  "keywords": [
    "git",
    "github",
    "dashboard",
    "terminal",
    "oss",
    "maintainer"
  ],
  "author": "Roger Chappel",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/rogerchappel/repobeacon.git"
  },
  "homepage": "https://github.com/rogerchappel/repobeacon#readme",
  "bugs": {
    "url": "https://github.com/rogerchappel/repobeacon/issues"
  },
  "devDependencies": {
    "@types/node": "^24.9.1",
    "tsx": "^4.20.6",
    "typescript": "^5.9.3"
  }
}
